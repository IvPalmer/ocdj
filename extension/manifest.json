{
  "manifest_version": 3,
  "name": "OCDJ Dig",
  "version": "1.1.0",
  "description": "Add tracks to your OCDJ Wanted List from Discogs, Bandcamp, YouTube, SoundCloud, and Spotify",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": [
    "http://localhost:8002/*",
    "http://127.0.0.1:8002/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "side-panel/panel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; frame-src http://localhost:8002 http://127.0.0.1:8002 https://bandcamp.com https://w.soundcloud.com https://open.spotify.com"
  },
  "content_scripts": [
    {
      "matches": ["*://*.discogs.com/*"],
      "js": ["content/shared.js", "content/discogs.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.bandcamp.com/*"],
      "js": ["content/shared.js", "content/bandcamp.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/shared.js", "content/youtube.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.soundcloud.com/*"],
      "js": ["content/shared.js", "content/soundcloud.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://open.spotify.com/*"],
      "js": ["content/shared.js", "content/spotify.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
