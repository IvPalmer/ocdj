# DJ Tools Environment Variables
# Copy to .env and fill in your values

# slskd API key (from slskd web UI > Settings > Security)
SLSKD_API_KEY=

# AcoustID API key (https://acoustid.org/new-application)
ACOUSTID_API_KEY=

# Spotify (Phase 3+)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Telegram (Phase 3+)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
