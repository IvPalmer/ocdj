# DJ Tools Environment Variables
# Copy to .env and fill in your values

# slskd API key (from slskd web UI > Settings > Security)
SLSKD_API_KEY=

# Dedicated Soulseek network account for slskd. Keep these values only in .env.
SLSKD_SLSK_USERNAME=
SLSKD_SLSK_PASSWORD=

# AcoustID API key (https://acoustid.org/new-application)
ACOUSTID_API_KEY=

# Spotify (Phase 3+)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube downloader (yt-dlp). Authenticated cookies make YouTube treat the
# server as a signed-in user, which all but eliminates the intermittent
# "Sign in to confirm you're not a bot" challenge on datacenter IPs. If the
# cookies expire, yt-dlp falls back to anonymous access (still works most of
# the time). Prod mounts a Netscape cookies.txt at the path below (see the
# secrets bind mount in docker-compose.prod.yml); refresh it by re-exporting
# from a logged-in browser. YOUTUBE_PROXY is an optional egress override.
YOUTUBE_COOKIES=/srv/ocdj/secrets/youtube_cookies.txt
YOUTUBE_COOKIES_FROM_BROWSER=
YOUTUBE_PROXY=

# Telegram (Phase 3+)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
